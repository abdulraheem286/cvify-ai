rules_version = '2';

// CVify AI — each signed-in user can read/write ONLY their own data.
// Paste this in Firebase console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/cvs/{cvId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/templates/{templateId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Blog engagement — public. Likes are an anonymous counter; comments are
    // anonymous (name + text). No auth required (this is a public blog).
    match /blogPosts/{slug} {
      allow read: if true;
      // Only the `likes` counter may be written, and only as an integer.
      allow write: if request.resource.data.keys().hasOnly(['likes'])
                   && request.resource.data.likes is int;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['name', 'text', 'createdAt'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 60
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }
  }
}
